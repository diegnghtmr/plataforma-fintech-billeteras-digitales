    {
      "name": "02 — Billeteras",
      "item": [
        {
          "name": "POST /users/{userId}/wallets  (WALLET-001)",
          "event": [{
            "listen": "test",
            "script": {"type": "text/javascript", "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('walletA1', pm.response.json().code);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"code\": \"{{walletA1}}\",\n  \"name\": \"Gastos diarios\",\n  \"type\": \"DAILY_EXPENSES\"\n}"},
