            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"type\": \"RECHARGE\",\n  \"sourceUserId\": \"{{userIdA}}\",\n  \"sourceWalletId\": \"{{walletA1}}\",\n  \"amount\": 300,\n  \"scheduledAt\": \"2020-01-01T00:00:00Z\",\n  \"description\": \"Ahorro automático semanal\"\n}"},
            "url": {"raw": "{{baseUrl}}/scheduled-operations", "host": ["{{baseUrl}}"], "path": ["scheduled-operations"]}
