            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Ana M.\",\n  \"email\": \"ana.m@example.com\"\n}"},
            "url": {"raw": "{{baseUrl}}/users/{{userIdA}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userIdA}}"]}
