    {
      "name": "03 — Operaciones financieras",
      "item": [
        {
          "name": "POST recharge  (20000 → 200 pts)",
          "event": [{
            "listen": "test",
            "script": {"type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('rechargeTxId', pm.response.json().id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"amount\": 20000,\n  \"description\": \"Recarga inicial\"\n}"},
            "url": {"raw": "{{baseUrl}}/users/{{userIdA}}/wallets/{{walletA1}}/recharge", "host": ["{{baseUrl}}"], "path": ["users", "{{userIdA}}", "wallets", "{{walletA1}}", "recharge"]}
          }
        },
        {
          "name": "POST withdraw  (1000 → 20 pts)",
          "event": [{
            "listen": "test",
            "script": {"type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('withdrawTxId', pm.response.json().id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"amount\": 1000,\n  \"description\": \"Retiro cajero\"\n}"},
            "url": {"raw": "{{baseUrl}}/users/{{userIdA}}/wallets/{{walletA1}}/withdraw", "host": ["{{baseUrl}}"], "path": ["users", "{{userIdA}}", "wallets", "{{walletA1}}", "withdraw"]}
          }
        },
        {
          "name": "POST internal transfer  (500 → 15 pts)",
          "event": [{
            "listen": "test",
            "script": {"type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('internalTxId', pm.response.json().id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"sourceWalletId\": \"{{walletA1}}\",\n  \"targetWalletId\": \"{{walletA2}}\",\n  \"amount\": 500,\n  \"description\": \"A ahorro\"\n}"},
            "url": {"raw": "{{baseUrl}}/users/{{userIdA}}/transfers/internal", "host": ["{{baseUrl}}"], "path": ["users", "{{userIdA}}", "transfers", "internal"]}
          }
        },
        {
          "name": "POST external transfer  (15000 → dispara FraudEvent)",
          "event": [{
            "listen": "test",
            "script": {"type": "text/javascript", "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('externalSentTxId', pm.response.json().outgoingTransaction.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"sourceUserId\": \"{{userIdA}}\",\n  \"sourceWalletId\": \"{{walletA1}}\",\n  \"targetUserId\": \"{{userIdB}}\",\n  \"targetWalletId\": \"{{walletB1}}\",\n  \"amount\": 15000,\n  \"description\": \"Pago grande\"\n}"},
            "url": {"raw": "{{baseUrl}}/transfers/external", "host": ["{{baseUrl}}"], "path": ["transfers", "external"]}
          }
        },
        {
          "name": "POST recharge x4 rápido  (gatilla HIGH_VELOCITY)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"amount\": 500,\n  \"description\": \"velocity test — correr 4 veces seguidas\"\n}"},
            "url": {"raw": "{{baseUrl}}/users/{{userIdA}}/wallets/{{walletA1}}/recharge", "host": ["{{baseUrl}}"], "path": ["users", "{{userIdA}}", "wallets", "{{walletA1}}", "recharge"]}
          }
        }
      ]
