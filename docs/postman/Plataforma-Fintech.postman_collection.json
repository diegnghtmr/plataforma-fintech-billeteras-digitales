    {
      "name": "01 — Usuarios",
      "item": [
        {
          "name": "POST /users  (crear USR001)",
          "event": [{
            "listen": "test",
            "script": {"type": "text/javascript", "exec": [
              "pm.test('201 Created', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('userIdA', body.id);"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"id\": \"{{userIdA}}\",\n  \"name\": \"Ana Martínez\",\n  \"email\": \"ana@example.com\"\n}"},
            "url": {"raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"]}
          }
        },
        {
          "name": "POST /users  (crear USR002)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"id\": \"{{userIdB}}\",\n  \"name\": \"Bruno Páez\",\n  \"email\": \"bruno@example.com\"\n}"},
            "url": {"raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"]}
          }
        },
        {
          "name": "GET /users/{userId}",
          "request": {
            "method": "GET",
            "url": {"raw": "{{baseUrl}}/users/{{userIdA}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userIdA}}"]}
          }
