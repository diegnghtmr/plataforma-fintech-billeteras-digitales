# Copy this file to `.env` and fill in real values. Do not commit `.env`.
# Backend AI provider configuration — OpenRouter (OpenAI-compatible).

# Provider switch: `openrouter` enables the real adapter; `none` (default) keeps the NoOp adapter.
APP_AI_PROVIDER=openrouter

# Required when APP_AI_PROVIDER=openrouter.
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key

# OpenRouter API base. Defaults are safe for production.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Free model on OpenRouter. Alternatives: `google/gemini-2.0-flash-exp:free`,
# `mistralai/mistral-7b-instruct:free`, `qwen/qwen-2.5-7b-instruct:free`.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional but recommended by OpenRouter for attribution / rate limits.
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=Plataforma Fintech Billeteras Digitales

# Safety limits for the AI surface.
APP_AI_MAX_USER_MESSAGE_LENGTH=1000
APP_AI_REQUEST_TIMEOUT_SECONDS=30
APP_AI_CACHE_TTL_MINUTES=10
